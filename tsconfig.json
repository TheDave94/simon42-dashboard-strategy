{
  "include": ["src/**/*"],
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "resolveJsonModule": true,
    "allowJs": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "strictNullChecks": true,
    "noFallthroughCasesInSwitch": true,
    // Indexed access of T returns `T | undefined`, forcing every
    // `hass.states[id]` / `entities[i]` to be guarded explicitly.
    // Catches the "value isn't there" bug class at type-check time.
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    // Cards use stage-3 standard decorators (`@property() accessor x`)
    // since v2.2 — the `accessor` keyword owns the slot, so the
    // [[Define]] semantics no longer conflict with Lit's reactivity.
    "useDefineForClassFields": true
  }
}
